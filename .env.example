# Supabase Credentials (Required for frontend database sync and file storage)
# In Vite, client-side variables must be prefixed with VITE_ to be exposed via import.meta.env
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Secondary / Direct PostgreSQL Connection (Typically used in serverless/backend layers)
POSTGRES_URL=postgres://default:password@host-domain.postgres.vercel-storage.com:5432/verceldb
POSTGRES_PRISMA_URL=postgres://default:password@host-domain.postgres.vercel-storage.com:5432/verceldb?pgbouncer=true
POSTGRES_URL_NON_POOLING=postgres://default:password@host-domain.postgres.vercel-storage.com:5432/verceldb
POSTGRES_USER=default
POSTGRES_HOST=host-domain.postgres.vercel-storage.com
POSTGRES_PASSWORD=password
POSTGRES_DATABASE=verceldb

# Supabase Auth Secrets (Internal server roles)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
